<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.Quiet" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/ciano</item>
        <item name="colorPrimaryVariant">@color/ciano_escuro</item>
        <item name="colorOnPrimary">@color/preto</item>
        <item name="colorSecondary">@color/verde</item>
        <item name="colorSecondaryVariant">@color/verde_escuro</item>
        <item name="colorOnSecondary">@color/preto</item>
        <item name="colorError">@color/vermelho</item>
        <item name="colorOnError">@color/white</item>
        <item name="android:colorBackground">@color/bg_tela</item>
        <item name="colorSurface">@color/bg_card</item>
        <item name="colorOnSurface">@color/texto_primario</item>
        <item name="colorOnBackground">@color/texto_primario</item>
        <item name="android:statusBarColor">@color/preto</item>
        <item name="android:navigationBarColor">@color/preto</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:textColorPrimary">@color/texto_primario</item>
        <item name="android:textColorSecondary">@color/texto_secundario</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="materialAlertDialogTheme">@style/Theme.Quiet.Dialog</item>
    </style>

    <style name="Theme.Quiet.NoActionBar" parent="Theme.Quiet">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="Theme.Quiet.Dialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="colorPrimary">@color/ciano</item>
        <item name="colorSurface">@color/cinza_escuro</item>
        <item name="colorOnSurface">@color/texto_primario</item>
    </style>

    <!-- Keep legacy theme name as alias -->
    <style name="Theme.BloqueadorBR" parent="Theme.Quiet"/>
    <style name="Theme.BloqueadorBR.NoActionBar" parent="Theme.Quiet.NoActionBar"/>
    <style name="Theme.BloqueadorBR.Dialog" parent="Theme.Quiet.Dialog"/>

    <!-- Typography -->
    <style name="TextoTitulo" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textSize">@dimen/text_title</item>
        <item name="android:textColor">@color/texto_primario</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">-0.01</item>
    </style>

    <style name="TextoSubtitulo" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textSize">@dimen/text_subtitle</item>
        <item name="android:textColor">@color/texto_secundario</item>
        <item name="android:lineSpacingExtra">4dp</item>
    </style>

    <style name="TextoCard" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textSize">@dimen/text_subtitle</item>
        <item name="android:textColor">@color/texto_primario</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextoCardDesc" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textSize">@dimen/text_caption</item>
        <item name="android:textColor">@color/texto_secundario</item>
        <item name="android:lineSpacingExtra">2dp</item>
    </style>

    <style name="TextoBotao" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:textSize">@dimen/text_body</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <!-- Buttons with improved touch targets -->
    <style name="BotaoPrimario" parent="Widget.Material3.Button">
        <item name="android:textAppearance">@style/TextoBotao</item>
        <item name="android:minHeight">@dimen/touch_target_min</item>
        <item name="cornerRadius">@dimen/corner_radius_button</item>
        <item name="backgroundTint">@color/ciano</item>
        <item name="android:textColor">@color/preto</item>
        <item name="android:paddingStart">@dimen/spacing_lg</item>
        <item name="android:paddingEnd">@dimen/spacing_lg</item>
    </style>

    <style name="BotaoSecundario" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:textAppearance">@style/TextoBotao</item>
        <item name="android:minHeight">@dimen/touch_target_min</item>
        <item name="cornerRadius">@dimen/corner_radius_button</item>
        <item name="strokeColor">@color/ciano</item>
        <item name="android:textColor">@color/ciano</item>
        <item name="android:paddingStart">@dimen/spacing_lg</item>
        <item name="android:paddingEnd">@dimen/spacing_lg</item>
    </style>

    <style name="BotaoPerigo" parent="Widget.Material3.Button">
        <item name="android:textAppearance">@style/TextoBotao</item>
        <item name="android:minHeight">@dimen/touch_target_min</item>
        <item name="cornerRadius">@dimen/corner_radius_button</item>
        <item name="backgroundTint">@color/vermelho</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:paddingStart">@dimen/spacing_lg</item>
        <item name="android:paddingEnd">@dimen/spacing_lg</item>
    </style>

    <!-- Cards -->
    <style name="CardDashboard" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/bg_card</item>
        <item name="cardCornerRadius">@dimen/corner_radius_card</item>
        <item name="cardElevation">4dp</item>
        <item name="contentPadding">@dimen/card_padding_vertical</item>
        <item name="android:layout_marginBottom">@dimen/spacing_md</item>
    </style>

    <!-- Content wrapper for tablet centering -->
    <style name="ContentWrapper">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:paddingStart">@dimen/spacing_lg</item>
        <item name="android:paddingEnd">@dimen/spacing_lg</item>
        <item name="android:paddingTop">@dimen/spacing_md</item>
        <item name="android:paddingBottom">@dimen/spacing_md</item>
    </style>
</resources>