<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_tela"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="@dimen/spacing_lg">

        <!-- Max width wrapper for tablets -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:maxWidth="@dimen/content_max_width"
            android:layout_gravity="center_horizontal">

            <ImageView
                android:layout_width="@dimen/icon_size_xlarge"
                android:layout_height="@dimen/icon_size_xlarge"
                android:layout_marginTop="@dimen/spacing_xl"
                android:layout_gravity="center_horizontal"
                android:src="@drawable/ic_logo"
                android:contentDescription="@string/app_name" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xl"
                android:text="@string/onb_titulo"
                android:textAppearance="@style/TextoTitulo"
                android:gravity="center" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md"
                android:text="@string/onb_subtitulo"
                android:textAppearance="@style/TextoSubtitulo"
                android:gravity="center" />

            <!-- Benefits list -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xl"
                app:cardBackgroundColor="@color/bg_card"
                app:cardCornerRadius="@dimen/corner_radius_card"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_md">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingTop="@dimen/spacing_sm"
                        android:paddingBottom="@dimen/spacing_sm"
                        android:paddingStart="@dimen/spacing_sm"
                        android:paddingEnd="@dimen/spacing_sm"
                        android:minHeight="@dimen/touch_target_min">
                        <ImageView
                            android:layout_width="@dimen/icon_size_small"
                            android:layout_height="@dimen/icon_size_small"
                            android:src="@drawable/ic_check"
                            app:tint="@color/verde"
                            android:contentDescription="@string/onb_benef1" />
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="@dimen/spacing_md"
                            android:text="@string/onb_benef1"
                            android:textColor="@color/texto_primario"
                            android:textSize="@dimen/text_body" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingTop="@dimen/spacing_sm"
                        android:paddingBottom="@dimen/spacing_sm"
                        android:paddingStart="@dimen/spacing_sm"
                        android:paddingEnd="@dimen/spacing_sm"
                        android:minHeight="@dimen/touch_target_min">
                        <ImageView
                            android:layout_width="@dimen/icon_size_small"
                            android:layout_height="@dimen/icon_size_small"
                            android:src="@drawable/ic_check"
                            app:tint="@color/verde"
                            android:contentDescription="@string/onb_benef2" />
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="@dimen/spacing_md"
                            android:text="@string/onb_benef2"
                            android:textColor="@color/texto_primario"
                            android:textSize="@dimen/text_body" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingTop="@dimen/spacing_sm"
                        android:paddingBottom="@dimen/spacing_sm"
                        android:paddingStart="@dimen/spacing_sm"
                        android:paddingEnd="@dimen/spacing_sm"
                        android:minHeight="@dimen/touch_target_min">
                        <ImageView
                            android:layout_width="@dimen/icon_size_small"
                            android:layout_height="@dimen/icon_size_small"
                            android:src="@drawable/ic_check"
                            app:tint="@color/verde"
                            android:contentDescription="@string/onb_benef3" />
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="@dimen/spacing_md"
                            android:text="@string/onb_benef3"
                            android:textColor="@color/texto_primario"
                            android:textSize="@dimen/text_body" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingTop="@dimen/spacing_sm"
                        android:paddingBottom="@dimen/spacing_sm"
                        android:paddingStart="@dimen/spacing_sm"
                        android:paddingEnd="@dimen/spacing_sm"
                        android:minHeight="@dimen/touch_target_min">
                        <ImageView
                            android:layout_width="@dimen/icon_size_small"
                            android:layout_height="@dimen/icon_size_small"
                            android:src="@drawable/ic_check"
                            app:tint="@color/verde"
                            android:contentDescription="@string/onb_benef4" />
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="@dimen/spacing_md"
                            android:text="@string/onb_benef4"
                            android:textColor="@color/texto_primario"
                            android:textSize="@dimen/text_body" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Permissions header -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xxl"
                android:text="@string/onb_permissao_titulo"
                android:textAppearance="@style/TextoCard"
                android:textColor="@color/ciano" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:text="@string/onb_permissao_desc"
                android:textColor="@color/texto_secundario"
                android:textSize="@dimen/text_caption"
                android:gravity="center"
                android:lineSpacingExtra="2dp" />

            <LinearLayout
                android:id="@+id/listaPermissoes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_lg"
                android:orientation="vertical">

                <!-- Permission items inserted programmatically -->
            </LinearLayout>

            <Button
                android:id="@+id/btnConceder"
                style="@style/BotaoPrimario"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xl"
                android:minHeight="@dimen/touch_target_min"
                android:text="@string/onb_btn_conceder" />

            <Button
                android:id="@+id/btnProximo"
                style="@style/BotaoSecundario"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md"
                android:layout_marginBottom="@dimen/spacing_xxl"
                android:minHeight="@dimen/touch_target_min"
                android:text="@string/onb_btn_comecar"
                android:enabled="false" />

        </LinearLayout>
    </LinearLayout>
</ScrollView>